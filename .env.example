# ===========================
# Cortex Backend - Environment Variables
# ===========================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration
DB_TYPE=mongo
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cortex-backend?retryWrites=true&w=majority
POSTGRES_URI=postgresql://user:password@host:5432/cortex

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-min-32-chars

# Email Configuration (for password reset, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Vercel specific (auto-set by Vercel)
# VERCEL=1